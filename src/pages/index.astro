      "year": 2016,
      "tracks": [
        "untitled 01",
        "untitled 02",
        "untitled 03",
        "untitled 04",
        "untitled 05",
        "untitled 06",
        "untitled 07",
        "untitled 08"
      ]
    },
    {
      "name": "DAMN.",
      "year": 2017,
      "tracks": [
        "BLOOD.",
        "DNA.",
        "YAH.",
        "ELEMENT.",
        "FEEL.",
        "LOYALTY.",
        "PRIDE.",
        "HUMBLE.",
        "LUST.",
        "LOVE.",
        "XXX.",
        "FEAR.",
        "GOD.",
        "DUCKWORTH."
      ]
    },
    {
      "name": "Mr. Morale & The Big Steppers",
      "year": 2022,
      "tracks": [
        "United in Grief",
        "N95",
        "Worldwide Steppers",
        "Die Hard",
        "Father Time",
        "Rich (Interlude)",
        "Rich Spirit",
        "We Cry Together",
        "Purple Hearts",
        "Count Me Out",
        "Crown",
        "Silent Hill",
        "Savior (Interlude)",
        "Savior",
        "Auntie Diaries",
        "Mr. Morale",
        "Mother I Sober",
        "Mirror"
      ]
    },
    {
      "name": "GNX",
      "year": 2024,
      "tracks": [
        "wacced out murals",
        "squabble up",
        "luther",
        "man at the garden",
        "hey now",
        "reincarnated",
        "tv off",
        "dodger blue",
        "peekaboo",
        "heart pt. 6",
        "gloria",
        "gnx"
      ]
    }
  ]
};

const COLORS = ["#7F77DD","#1D9E75","#D85A30","#D4537E","#378ADD","#BA7517","#E24B4A","#639922"];
const SKIP_ALBUM = /\b(live|concert|tour|session|unplugged|acoustic|festival|mixtape|compilation|greatest hits|best of|collection|anthology|remix|remixes|\bep\b|single|instrumental|karaoke|tribute|cover|deluxe)\b/i;
const S = { artistName: "", albums: [], trackedWords: [], chart: null };

function showScreen(id) {
  document.querySelectorAll(".screen").forEach(el => el.classList.remove("active"));
  document.getElementById("screen-" + id).classList.add("active");
}
function showError(msg) {
  const el = document.getElementById("error-box");
  el.textContent = msg; el.style.display = msg ? "block" : "none";
}
function setProgress(cur, tot, label) {
  const pct = tot > 0 ? Math.round((cur / tot) * 100) : 0;
  document.getElementById("prog-fill").style.width = pct + "%";
  document.getElementById("prog-pct").textContent = pct + "%";
  document.getElementById("prog-song").textContent = label || "";
  document.getElementById("loading-status").textContent = tot > 0 ? cur + " of " + tot + " songs" : (label || "Working…");
}
function countWord(text, word) {
  if (!text || !word) return 0;
  const e = word.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  return (text.match(new RegExp("\\b" + e + "\\b", "g")) || []).length;
}

async function handleSearch() {
  const query = document.getElementById("artist-input").value.trim();
  if (!query) { showError("Please select an artist."); return; }
  showError(""); S.albums = []; S.artistName = query;
  showScreen("loading");
  document.getElementById("loading-name").textContent = query;
  document.getElementById("loading-initials").textContent = query[0];
  document.getElementById("loading-img").style.display = "none";
  document.getElementById("loading-initials").style.display = "";

  try {
    const discography = DISCOGRAPHIES[query];
    if (!discography) { showScreen("setup"); showError("No discography found for this artist."); return; }

    const totalTracks = discography.reduce((s, a) => s + a.tracks.length, 0);
    let done = 0;

    for (const album of discography) {
      const albumSongs = [];
      for (const trackName of album.tracks) {
        setProgress(done, totalTracks, trackName);
        try {
          const res = await fetch(
            "https://lrclib.net/api/get?artist_name=" + encodeURIComponent(query) +
            "&track_name=" + encodeURIComponent(trackName) +
            "&album_name=" + encodeURIComponent(album.name)
          );
          if (res.ok) {
            const data = await res.json();
            const raw = data.plainLyrics || "";
            if (raw) {
              const lyrics = raw.toLowerCase().replace(/[^a-z0-9\s']/g, " ").replace(/\s+/g, " ").trim();
              const wordCount = lyrics.split(/\s+/).filter(Boolean).length;
              albumSongs.push({ title: trackName, lyrics, wordCount });
            }
          }
        } catch {}
        done++;
        await new Promise(r => setTimeout(r, 80));
      }
      S.albums.push({ name: album.name, year: album.year, songs: albumSongs });
    }

    S.albums.sort((a, b) => (a.year || 0) - (b.year || 0));
    initAnalyze();
    showScreen("analyze");

  } catch (e) {
    showScreen("setup");
    showError("Something went wrong: " + (e.message || e));
  }
}

function stopFetch() { /* no-op — lrclib loads instantly */ }

function initAnalyze() {
  const totalSongs = S.albums.reduce((s, a) => s + a.songs.length, 0);
  const totalWords = S.albums.reduce((s, a) => s + a.songs.reduce((ss, sg) => ss + sg.wordCount, 0), 0);
  document.getElementById("hdr-artist").textContent = S.artistName;
  document.getElementById("stat-albums").textContent = S.albums.length;
  document.getElementById("stat-songs").textContent = totalSongs;
  document.getElementById("stat-words").textContent = totalWords > 999 ? Math.round(totalWords / 1000) + "k" : totalWords;

  // Auto-detect top words
  S.trackedWords = getTopWords(8);
  document.getElementById("chip-list").innerHTML = "";
  document.getElementById("empty-hint").style.display = S.trackedWords.length ? "none" : "block";
  document.getElementById("chart-empty").style.display = "flex";
  document.getElementById("chart-container").style.display = "none";
  if (S.chart) { S.chart.destroy(); S.chart = null; }
  renderChips();
  if (S.trackedWords.length) updateChart();
}

function getTopWords(n) {
  const STOP = new Set([
    "the","a","an","and","or","but","in","on","at","to","for","of","with",
    "is","it","its","i","my","me","we","you","your","he","she","they","them",
    "that","this","was","are","be","been","have","has","had","do","did","will",
    "can","so","if","as","up","out","not","no","all","just","like","what",
    "when","who","how","more","about","from","get","got","go","im","dont",
    "know","one","see","cause","yeah","oh","ah","ay","uh","na","da","gonna",
    "gotta","wanna","tryna","til","em","let","make","made","come","came",
    "said","say","tell","told","went","want","need","back","now","then",
    "there","here","some","than","into","over","after","its","its","our",
    "their","been","still","even","never","always","every","us","him","her",
    "by","was","were","would","could","should","must","may","might","ill",
    "id","ive","thats","its","dont","cant","wont","aint","bout","cause",
    "cuz","nigga","niggas","shit","fuck","ass","bitch","damn","real","time",
    "man","way","day","life","world","feel","thing","things","little","put",
    "take","took","right","down","around","same","through","between","while",
    "these","those","much","too","very","own","off","again","where","both",
    "few","more","most","other","into","only","also","new","first","last",
    "long","great","little","own","right","big","high","different","small",
    "large","next","early","young","important","public","private","real"
  ]);

  // Count every word across all albums
  const freq = {};
  for (const album of S.albums) {
    for (const song of album.songs) {
      if (!song.lyrics) continue;
      for (const word of song.lyrics.split(/\s+/)) {
        const w = word.replace(/[^a-z']/g, "");
        if (w.length < 3) continue;
        if (STOP.has(w)) continue;
        freq[w] = (freq[w] || 0) + 1;
      }
    }
  }

  return Object.entries(freq)
    .sort((a, b) => b[1] - a[1])
    .slice(0, n)
    .map(([w]) => w);
}

function resetApp() {
  S.albums = []; S.artistName = ""; S.trackedWords = [];
  if (S.chart) { S.chart.destroy(); S.chart = null; }
  showScreen("setup");
}

function buildChartData() {
  if (!S.albums.length || !S.trackedWords.length) return null;
  const labels = S.albums.map(a => { const l = a.year ? a.name + " (" + a.year + ")" : a.name; return l.length > 32 ? l.substring(0, 30) + "…" : l; });
  const datasets = S.trackedWords.map((word, i) => ({
    label: word,
    data: S.albums.map(album => {
      const tw = album.songs.reduce((s, sg) => s + sg.wordCount, 0);
      const tc = album.songs.reduce((s, sg) => s + countWord(sg.lyrics, word), 0);
      return tw > 0 ? Math.round((tc / tw) * 1000 * 10) / 10 : 0;
    }),
    borderColor: COLORS[i % COLORS.length],
    backgroundColor: COLORS[i % COLORS.length] + "28",
    pointBackgroundColor: COLORS[i % COLORS.length],
    pointRadius: 6, pointHoverRadius: 8,
    tension: 0.3, fill: false, borderWidth: 2,
  }));
  return { labels, datasets };
}

function updateChart() {
  const data = buildChartData();
  if (!data) {
    document.getElementById("chart-empty").style.display = "flex";
    document.getElementById("chart-container").style.display = "none";
    return;
  }
  document.getElementById("chart-empty").style.display = "none";
  document.getElementById("chart-container").style.display = "flex";
  document.getElementById("chart-legend").innerHTML = S.trackedWords.map((w, i) =>
    `<span style="display:flex;align-items:center;gap:4px;"><span style="width:10px;height:10px;border-radius:2px;background:${COLORS[i % COLORS.length]};"></span>${w}</span>`
  ).join("");
  const isDark = window.matchMedia?.("(prefers-color-scheme: dark)").matches;
  const gridCol = isDark ? "rgba(255,255,255,0.07)" : "rgba(0,0,0,0.06)";
  const tickCol = isDark ? "rgba(200,195,185,0.5)" : "rgba(80,75,65,0.6)";
  const ttBg  = isDark ? "rgba(25,23,20,0.96)" : "rgba(255,255,255,0.97)";
  const ttBorder = isDark ? "rgba(255,255,255,0.1)" : "rgba(0,0,0,0.1)";
  const ttText = isDark ? "#e8e3da" : "#1a1917";
  if (S.chart) {
    S.chart.data.labels = data.labels;
    S.chart.data.datasets = data.datasets;
    S.chart.update();
  } else {
    const ctx = document.getElementById("lyricsChart").getContext("2d");
    S.chart = new Chart(ctx, {
      type: "line", data,
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: ttBg, borderColor: ttBorder, borderWidth: 1,
            titleColor: tickCol, bodyColor: ttText,
            callbacks: { label: ctx => `"${ctx.dataset.label}": ${ctx.parsed.y.toFixed(1)} per 1k words` }
          }
        },
        scales: {
          x: { grid: { color: gridCol }, ticks: { maxRotation: 35, font: { size: 11 }, color: tickCol, autoSkip: false }, border: { display: false } },
          y: { grid: { color: gridCol }, ticks: { font: { size: 11 }, color: tickCol }, border: { display: false }, beginAtZero: true }
        }
      }
    });
  }
}

function addWord() {
  const inp = document.getElementById("word-input");
  const w = inp.value.trim().toLowerCase();
  if (!w || S.trackedWords.includes(w) || S.trackedWords.length >= COLORS.length) return;
  inp.value = ""; S.trackedWords.push(w);
  renderChips(); updateChart();
}
function removeWord(w) {
  S.trackedWords = S.trackedWords.filter(x => x !== w);
  renderChips(); updateChart();
}
function renderChips() {
  const cl = document.getElementById("chip-list");
  const eh = document.getElementById("empty-hint");
  if (!S.trackedWords.length) { cl.innerHTML = ""; eh.style.display = "block"; return; }
  eh.style.display = "none";
  cl.innerHTML = S.trackedWords.map((w, i) =>
    `<div class="word-chip" style="border-left:3px solid ${COLORS[i % COLORS.length]};">
      <div class="chip-dot" style="background:${COLORS[i % COLORS.length]};"></div>
      <span style="flex:1;">${w}</span>
      <button class="chip-remove" onclick="removeWord('${w}')">×</button>
    </div>`
  ).join("");
}
</script>
</body>
</html>
