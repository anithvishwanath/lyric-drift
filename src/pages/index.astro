---
// Lyric Drift — src/pages/index.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Lyric Drift — Word Frequency Tracker</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --font-serif: Georgia, 'Times New Roman', serif;
    --font-mono: 'JetBrains Mono', 'Fira Mono', 'Courier New', monospace;
    --font-sans: system-ui, -apple-system, sans-serif;
    --color-bg: #faf9f7;
    --color-surface: #f2f0eb;
    --color-text: #1a1917;
    --color-text-secondary: #5f5e5a;
    --color-text-tertiary: #888780;
    --color-border: rgba(0,0,0,0.10);
    --color-border-strong: rgba(0,0,0,0.18);
    --color-danger-bg: #fcebeb;
    --color-danger-border: #f09595;
    --color-danger-text: #a32d2d;
    --radius-md: 8px;
    --radius-lg: 12px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #181715;
      --color-surface: #222119;
      --color-text: #edeae3;
      --color-text-secondary: #b4b2a9;
      --color-text-tertiary: #6e6d67;
      --color-border: rgba(255,255,255,0.09);
      --color-border-strong: rgba(255,255,255,0.16);
      --color-danger-bg: #2e1a1a;
      --color-danger-border: #791f1f;
      --color-danger-text: #f09595;
    }
  }

  html, body { height: 100%; background: var(--color-bg); color: var(--color-text); font-family: var(--font-sans); font-size: 16px; line-height: 1.6; }

  input, button {
    font-family: var(--font-sans); font-size: 0.88rem;
    color: var(--color-text); background: var(--color-bg);
    border: 0.5px solid var(--color-border-strong);
    border-radius: var(--radius-md); padding: 0.6rem 0.85rem;
    outline: none; transition: border-color 0.15s;
  }
  input:focus { border-color: var(--color-text-secondary); }
  button { cursor: pointer; background: transparent; padding: 0.6rem 1.1rem; }
  button:hover { background: var(--color-surface); }
  button:active { transform: scale(0.98); }
  a { color: var(--color-text-secondary); }

  .screen { display: none; }
  .screen.active { display: block; }

  #setup-wrap { max-width: 440px; margin: 0 auto; padding: 4rem 1.5rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.58rem; color: var(--color-text-tertiary); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.5rem; }
  .app-title { font-family: var(--font-serif); font-size: 3rem; font-weight: 500; line-height: 1.05; margin-bottom: 0.35rem; }
  .field-label { display: block; font-family: var(--font-mono); font-size: 0.6rem; color: var(--color-text-tertiary); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .error-box { padding: 0.65rem 0.9rem; background: var(--color-danger-bg); border: 0.5px solid var(--color-danger-border); border-radius: var(--radius-md); color: var(--color-danger-text); font-size: 0.82rem; margin-bottom: 0.9rem; display: none; }

  #loading-wrap { max-width: 380px; margin: 0 auto; padding: 5rem 1.5rem; text-align: center; }
  .prog-track { height: 2px; background: var(--color-border); border-radius: 1px; margin: 0.75rem 0 0.3rem; overflow: hidden; }
  .prog-fill { height: 100%; background: var(--color-text); border-radius: 1px; transition: width 0.3s ease; width: 0%; }

  #screen-analyze { display: flex; flex-direction: column; min-height: 100vh; }
  #analyze-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.8rem 1.5rem; border-bottom: 0.5px solid var(--color-border);
    flex-wrap: wrap; gap: 0.6rem;
    background: var(--color-bg); position: sticky; top: 0; z-index: 10;
  }
  #analyze-body { display: flex; flex: 1; min-height: 520px; }
  #word-sidebar { width: 220px; flex-shrink: 0; border-right: 0.5px solid var(--color-border); padding: 1.1rem; display: flex; flex-direction: column; gap: 0.9rem; }
  #chart-main { flex: 1; min-width: 0; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; }

  .stat-group { text-align: right; }
  .stat-label { font-family: var(--font-mono); font-size: 0.55rem; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.1em; }
  .stat-value { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 500; }

  .word-chip { display: flex; align-items: center; padding: 0.42rem 0.65rem; background: var(--color-surface); border: 0.5px solid var(--color-border); border-radius: var(--radius-md); font-family: var(--font-mono); font-size: 0.78rem; margin-bottom: 0.3rem; }
  .chip-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-right: 0.5rem; }
  .chip-remove { background: none; border: none; cursor: pointer; color: var(--color-text-tertiary); font-size: 1rem; line-height: 1; margin-left: auto; padding: 0 0 0 0.4rem; }
  .chip-remove:hover { color: var(--color-text); background: none; }

  .chart-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--color-text-tertiary); font-size: 0.88rem; gap: 0.4rem; }
  .unit-note { font-family: var(--font-mono); font-size: 0.58rem; color: var(--color-text-tertiary); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.5rem; }
  .tip-box { padding: 0.7rem; background: var(--color-surface); border-radius: var(--radius-md); font-size: 0.7rem; color: var(--color-text-tertiary); line-height: 1.5; }
</style>
</head>
<body>

<!-- Setup -->
<div id="screen-setup" class="screen active">
  <div id="setup-wrap">
    <div class="eyebrow">Word frequency tracker</div>
    <h1 class="app-title">Lyric<br><em>Drift</em></h1>
    <p style="font-size:0.82rem;color:var(--color-text-tertiary);margin-bottom:2.2rem;line-height:1.5;">
      Track how often words appear across an artist's studio albums — album by album.
    </p>
    <div id="error-box" class="error-box"></div>
    <div style="margin-bottom:1.4rem;">
      <label class="field-label" for="artist-input">Artist</label>
      <input type="text" id="artist-input" placeholder="e.g. Radiohead, Phoebe Bridgers, Kendrick…" style="width:100%;" onkeydown="if(event.key==='Enter') handleSearch()" />
    </div>
    <button onclick="handleSearch()" style="width:100%;padding:0.85rem;">Begin Analysis →</button>
    <div style="margin-top:1.8rem;display:flex;gap:1.2rem;font-family:var(--font-mono);font-size:0.58rem;color:var(--color-text-tertiary);">
      <span>lyrics via lrclib.net</span><span>·</span><span>no api key needed</span><span>·</span><span>studio albums curated</span>
    </div>
  </div>
</div>

<!-- Loading -->
<div id="screen-loading" class="screen">
  <div id="loading-wrap">
    <div id="loading-avatar" style="width:64px;height:64px;border-radius:50%;margin:0 auto 1.1rem;background:var(--color-surface);border:0.5px solid var(--color-border);overflow:hidden;display:flex;align-items:center;justify-content:center;">
      <img id="loading-img" style="width:100%;height:100%;object-fit:cover;display:none;" />
      <span id="loading-initials" style="font-family:var(--font-serif);font-size:1.4rem;color:var(--color-text-tertiary);"></span>
    </div>
    <h2 id="loading-name" style="font-family:var(--font-serif);font-size:1.6rem;font-weight:500;margin-bottom:0.3rem;"></h2>
    <p id="loading-status" style="font-size:0.82rem;color:var(--color-text-secondary);margin-bottom:1.25rem;">Searching…</p>
    <div class="prog-track"><div class="prog-fill" id="prog-fill"></div></div>
    <div style="display:flex;justify-content:space-between;margin-bottom:2rem;">
      <span id="prog-song" style="font-size:0.68rem;color:var(--color-text-tertiary);font-family:var(--font-mono);max-width:72%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
      <span id="prog-pct" style="font-size:0.68rem;color:var(--color-text-tertiary);font-family:var(--font-mono);">0%</span>
    </div>
    <button onclick="stopFetch()" style="padding:0.55rem 1.25rem;font-size:0.8rem;">Stop &amp; Analyze Now</button>
    <p style="margin-top:0.75rem;font-size:0.7rem;color:var(--color-text-tertiary);">Fetching lyrics for each song — hang tight</p>
  </div>
</div>

<!-- Analyze -->
<div id="screen-analyze" class="screen">
  <div id="analyze-header">
    <div style="display:flex;align-items:center;gap:0.65rem;">
      <span style="font-family:var(--font-serif);font-size:1.05rem;font-weight:500;">Lyric<em>Drift</em></span>
      <span style="color:var(--color-border-strong);">|</span>
      <span id="hdr-artist" style="font-size:0.85rem;color:var(--color-text-secondary);"></span>
    </div>
    <div style="display:flex;align-items:center;gap:1.25rem;">
      <div class="stat-group"><div class="stat-label">Albums</div><div class="stat-value" id="stat-albums">—</div></div>
      <div class="stat-group"><div class="stat-label">Songs</div><div class="stat-value" id="stat-songs">—</div></div>
      <div class="stat-group"><div class="stat-label">Words</div><div class="stat-value" id="stat-words">—</div></div>
      <button onclick="resetApp()" style="padding:0.38rem 0.8rem;font-size:0.75rem;">New Search</button>
    </div>
  </div>
  <div id="analyze-body">
    <div id="word-sidebar">
      <div>
        <div class="field-label" style="margin-bottom:0.5rem;">Track a word</div>
        <div style="display:flex;gap:0.35rem;">
          <input type="text" id="word-input" placeholder="e.g. love, fire…" style="flex:1;min-width:0;" onkeydown="if(event.key==='Enter') addWord()" />
          <button onclick="addWord()" style="padding:0 0.7rem;font-size:1.1rem;flex-shrink:0;">+</button>
        </div>
      </div>
      <div id="chip-list"></div>
      <div id="empty-hint" style="padding:0.9rem;border:0.5px dashed var(--color-border-strong);border-radius:var(--radius-md);font-size:0.75rem;color:var(--color-text-tertiary);text-align:center;line-height:1.5;">
        Add words above to see how they drift across albums
      </div>
      <div style="margin-top:auto;">
        <div class="tip-box">
          <div style="font-family:var(--font-mono);font-size:0.55rem;color:var(--color-text-tertiary);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.25rem;">Y-axis unit</div>
          Occurrences per 1,000 words — normalizes for album length.
        </div>
      </div>
    </div>
    <div id="chart-main">
      <div id="chart-empty" class="chart-empty">
        <span style="font-family:var(--font-serif);font-size:2.2rem;color:var(--color-border-strong);">←</span>
        <span>Add a word to start tracking</span>
      </div>
      <div id="chart-container" style="display:none;flex-direction:column;flex:1;">
        <div class="unit-note">Word frequency · studio albums in release order · per 1,000 words</div>
        <div id="chart-legend" style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:0.75rem;font-size:12px;color:var(--color-text-secondary);"></div>
        <div style="position:relative;width:100%;height:400px;"><canvas id="lyricsChart"></canvas></div>
      </div>
    </div>
  </div>
</div>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script is:inline>
const DISCOGRAPHIES = {
  "Kendrick Lamar": [
    {
      "name": "Section.80",
      "year": 2011,
      "tracks": [
        "Fuck Your Ethnicity",
        "Hol' Up",
        "A.D.H.D",
        "No Joke",
        "Chapter Six",
        "Rigamortis",
        "Institutionalized",
        "Chapter Ten",
        "Ronald Reagan Era",
        "Poe Man's Dreams",
        "Blow My High",
        "Alien Girl",
        "No Makeup",
        "Keisha's Song",
        "HiiiPoWeR"
      ]
    },
    {
      "name": "good kid, m.A.A.d city",
      "year": 2012,
      "tracks": [
        "Sherane a.k.a Master Splinter's Daughter",
        "Bitch, Don't Kill My Vibe",
        "Backseat Freestyle",
        "The Art of Peer Pressure",
        "Money Trees",
